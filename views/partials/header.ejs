  </style>
</head>
<body>
  <nav>
    <div class="nav-container">
      <a href="/" class="logo">🏭 MSE Platform</a>
      
      <% if (user) { %>
        <div class="nav-menu">
          <% if (user.role === 'admin') { %>
            <a href="/admin/dashboard">Dashboard</a>
            <a href="/admin/orders/create">New Order</a>
            <a href="/admin/mse/pending">Pending MSEs</a>
            <a href="/admin/selections/pending">Selections</a>
          <% } else if (user.role === 'mse') { %>
            <a href="/mse/dashboard">Dashboard</a>
            <a href="/mse/orders/open">Browse Orders</a>
            <a href="/mse/selections/my">My Selections</a>
            <a href="/mse/ratings">Ratings</a>
          <% } %>
        </div>
        
        <div class="nav-links">
          <span class="user-greeting">👋 <%= user.name %></span>
          <a href="/auth/logout" class="logout-btn">Logout</a>
        </div>
      <% } else { %>
        <div class="nav-links">
          <a href="/auth/login">Login</a>
          <a href="/auth/register">Register as MSE</a>
        </div>
      <% } %>
    </div>
  </nav>

  <main class="container">
    <% if (success_msg && success_msg.length) { %>
      <div class="alert alert-success"><%= success_msg %></div>
    <% } %>
    <% if (error_msg && error_msg.length) { %>
      <div class="alert alert-error"><%= error_msg %></div>
    <% } %>
    <% if (locals.error && error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    
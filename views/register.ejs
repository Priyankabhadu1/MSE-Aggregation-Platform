<%- include('partials/header') %>

<div class="auth-container">
  <div class="auth-card">
    <h2>Register Your Business</h2>
    <p class="subtitle">Join as an MSE and start receiving bulk orders</p>
    
    <form action="/auth/register" method="POST">
      <div class="form-row">
        <div class="form-group">
          <label for="name">Full Name *</label>
          <input type="text" id="name" name="name" required placeholder="John Doe">
        </div>
        
        <div class="form-group">
          <label for="businessName">Business Name *</label>
          <input type="text" id="businessName" name="businessName" required placeholder="ABC Manufacturing">
        </div>
      </div>
      
      <div class="form-group">
        <label for="email">Email Address *</label>
        <input type="email" id="email" name="email" required placeholder="contact@yourbusiness.com">
      </div>
      
      <div class="form-group">
        <label for="password">Password *</label>
        <input type="password" id="password" name="password" required placeholder="Create a strong password">
        <small>Minimum 8 characters recommended</small>
      </div>
      
      <div class="form-group">
        <label for="registrationId">Registration ID (UDYAM / GST) *</label>
        <input type="text" id="registrationId" name="registrationId" required placeholder="UDYAM-MH-02-0000000">
        <small>This helps us verify your business authenticity</small>
      </div>
      
      <button type="submit" class="btn btn-primary btn-block">Register Business</button>
    </form>
    
    <p class="auth-footer">
      Already have an account? <a href="/auth/login">Login here</a>
    </p>
  </div>
</div>

<%- include('partials/footer') %>
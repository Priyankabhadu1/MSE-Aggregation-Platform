<%- include('../../partials/header') %>

<div class="page-header">
  <h1>All Orders</h1>
  <a href="/admin/orders/create" class="btn btn-primary">+ New Order</a>
</div>

<div class="table-responsive">
  <table class="data-table">
    <thead>
      <tr>
        <th>Description</th>
        <th>Quantity</th>
        <th>Price/Unit</th>
        <th>Total Value</th>
        <th>Deadline</th>
        <th>Status</th>
        <th>Created</th>
      </tr>
    </thead>
    <tbody>
      <% orders.forEach(order => { %>
        <tr>
          <td><%= order.description.substring(0, 60) %><%= order.description.length > 60 ? '...' : '' %></td>
          <td><%= order.totalQuantity.toLocaleString() %></td>
          <td>₹<%= order.pricePerUnit.toLocaleString() %></td>
          <td><strong>₹<%= (order.totalQuantity * order.pricePerUnit).toLocaleString() %></strong></td>
          <td><%= order.deadline.toDateString() %></td>
          <td><span class="badge badge-<%= order.status %>"><%= order.status %></span></td>
          <td><%= order.createdAt.toDateString() %></td>
        </tr>
      <% }) %>
      <% if (orders.length === 0) { %>
        <tr>
          <td colspan="7" class="empty-state">No orders created yet. <a href="/admin/orders/create">Create your first order</a></td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('../../partials/footer') %>
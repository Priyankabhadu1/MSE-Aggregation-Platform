<%- include('../../partials/header') %>

<div class="form-container">
  <div class="auth-card">
    <h2>Create New Order</h2>
    <p class="subtitle">Fill in the details below to create a new bulk order</p>
    
    <form action="/admin/orders" method="POST">
      <div class="form-group">
        <label for="description">Order Description *</label>
        <textarea id="description" name="description" rows="4" required placeholder="Describe the product/service in detail..."></textarea>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label for="totalQuantity">Total Quantity *</label>
          <input type="number" id="totalQuantity" name="totalQuantity" min="1" required placeholder="e.g., 1000">
        </div>
        
        <div class="form-group">
          <label for="pricePerUnit">Price per Unit (₹) *</label>
          <input type="number" id="pricePerUnit" name="pricePerUnit" step="0.01" min="0" required placeholder="e.g., 500">
        </div>
      </div>
      
      <div class="form-group">
        <label for="deadline">Deadline *</label>
        <input type="datetime-local" id="deadline" name="deadline" required>
      </div>
      
      <div class="form-group">
        <div class="alert alert-info" style="background: #e3f2fd; color: #1976d2;">
          <strong>💡 Note:</strong> MSEs will be able to select portions of this order. All selections require your approval.
        </div>
      </div>
      
      <div class="form-actions" style="display: flex; gap: 10px; margin-top: 20px;">
        <button type="submit" class="btn btn-primary">Create Order</button>
        <a href="/admin/dashboard" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>

<%- include('../../partials/footer') %>